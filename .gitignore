# ==============================
# Hello-Busan .gitignore
# ==============================

# ==============================
# Python
# ==============================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual Environment
venv/
env/
.venv/
.env/

# ==============================
# Environment Variables
# ==============================
.env
.env.local
.env.production
.env.development
*.env

# ==============================
# IDE / Editor
# ==============================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ==============================
# OS
# ==============================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==============================
# Node.js (if used later)
# ==============================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ==============================
# Logs
# ==============================
*.log
logs/

# ==============================
# Database
# ==============================
*.db
*.sqlite3

# ==============================
# AWS
# ==============================
*.pem
.aws/

# ==============================
# Misc
# ==============================
*.bak
*.tmp
*.temp
.cache/
