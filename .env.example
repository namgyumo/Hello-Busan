# ====================================
# Hello-Busan 환경변수 설정
# 이 파일을 .env로 복사하여 사용하세요
# cp .env.example .env
# ====================================

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# 공공데이터포털 API
DATA_API_KEY=your_data_portal_api_key

# 앱 설정
SECRET_KEY=your_secret_key_here
DEBUG=True
APP_ENV=development

# Sentry 모니터링 (선택)
SENTRY_DSN=

# AWS (배포 시)
AWS_REGION=ap-northeast-2
