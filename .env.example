# ====================================
# Hello-Busan 환경변수 설정
# 이 파일을 .env로 복사하여 사용하세요
# cp .env.example .env
# ====================================

# 앱 설정
APP_ENV=development
APP_PORT=8000
DEBUG=True
SECRET_KEY=your_secret_key_here

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# 공공데이터포털 API
DATA_API_KEY=your_data_portal_api_key

# 기상청 API
WEATHER_API_KEY=your_weather_api_key

# 부산 관광 API
BUSAN_TOUR_API_KEY=your_busan_tour_api_key

# Sentry 모니터링 (선택)
SENTRY_DSN=

# AWS (배포 시)
AWS_REGION=ap-northeast-2

# 캐시 TTL (초)
CACHE_TTL_CROWD=300
CACHE_TTL_WEATHER=1800
CACHE_TTL_SPOTS=86400

# ML
MODEL_PATH=ml_data/model.joblib
FALLBACK_ENABLED=true
